#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT="${1:-$ROOT_DIR/.bin/koder}"

mkdir -p "$(dirname "$OUT")"

VERSION="${VERSION:-0.1.0}"
COMMIT="${COMMIT:-$(git -C "$ROOT_DIR" rev-parse --short=12 HEAD)}"
if git -C "$ROOT_DIR" diff --quiet --ignore-submodules HEAD --; then
  DIRTY="${DIRTY:-false}"
else
  DIRTY="${DIRTY:-true}"
fi
BUILD_TIME="${BUILD_TIME:-$(date -u +"%Y-%m-%dT%H:%M:%SZ")}"

LDFLAGS=(
  "-X" "github.com/lkarlslund/koder/internal/version.Version=$VERSION"
  "-X" "github.com/lkarlslund/koder/internal/version.Commit=$COMMIT"
  "-X" "github.com/lkarlslund/koder/internal/version.Dirty=$DIRTY"
  "-X" "github.com/lkarlslund/koder/internal/version.BuildTime=$BUILD_TIME"
)

cd "$ROOT_DIR"
go build -ldflags "$(printf '%s ' "${LDFLAGS[@]}")" -o "$OUT" ./cmd/koder
echo "$OUT"
